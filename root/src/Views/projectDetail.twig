{% extends "base.twig" %}

{% block title %}{{ project.name }} - {% endblock %}

{% block head %}
    {{ parent() }}
    <script src="../../assets/js/deleteAlert.js" type="text/javascript"></script>
    <script src="../../assets/js/pagination.js" type="text/javascript"></script>
{% endblock %}

{% block mainContent %}
    {% if loggedIn %}
        <div class="editButtons">
            <a class="button" href="/project/edit?id={{ project.id }}">Projekt bearbeiten</a>
            <a class="button" onclick="deleteAlert('{{ project.name }}', '{{ project.id }}')">Projekt löschen</a>
        </div>
        <h1>{{ project.name }}</h1>
        {% if deleteError %}
            <h4 class="error delete">Das Projekt kann nicht gelöscht werden, weil noch Projekte existieren die diesem untergeordnet sind! Bitte Lösche diese zuerst!</h4>
        {% endif %}
        <p>{{ project.description }}</p>
        <form id="searchInProject" class="search" method="post" action="/search/search">
            <label>
                <input type="search" name="search" placeholder="{{ project.name }} durchsuchen">
            </label>
            <input type="hidden" name="project" value="{{ project.id }}">
            <label>
                <input type="submit" name="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
            </label>
        </form>
        {% if searched == true %}
            <ul class="searchResults">
                {% if articles is empty %}
                    <p>Zu deiner Suchanfrage wurden keine Ergebnisse gefunden.</p>
                {% else %}
                    {% for article in articles.__serialize %}
                        <li {% if article.empty %}class="emptyArticle"{% endif %}>
                            <a href="/article?id={{ article.id }}" class="article">
                                <h3>{{ article.headline }}</h3>
                                <p>Erstellt am {{ article.published|date("d.m.Y - H:i:s") }} von {{ article.createdBy.username }}</p>
                            </a>
                        </li>
                    {% endfor %}
                {% endif %}
            </ul>
        {% else %}
            <form id="articleFilter" method="get" action="/project/detail">
                <input type="hidden" name="id" value="{{ project.id }}">
                <label>Sortieren nach:
                    <select name="filter" onchange="this.form.submit()">
                        <option value="called" {% if filter == "called" %}selected{% endif %}>Beliebtheit</option>
                        <option value="headline" {% if filter == "headline" %}selected{% endif %}>Name, aufsteigend</option>
                        <option value="headline_down" {% if filter == "headline_down" %}selected{% endif %}>Name, absteigend</option>
                        <option value="published_new" {% if filter == "published_new" %}selected{% endif %}>Veröffentlichung, neuste</option>
                        <option value="published" {% if filter == "published" %}selected{% endif %}>Veröffentlichung, älteste</option>
                    </select>
                </label>
                <input type="hidden" name="page" value="{{ page }}">
            </form>
            <div class="articleList">
                <ul>
                    {% for article in articles.__serialize %}
                        <li {% if article.empty %}class="emptyArticle"{% endif %}>
                            <a href="/article?id={{ article.id }}" class="article">
                                <h3>{{ article.headline }}</h3>
                                <p>Erstellt am {{ article.published|date("d.m.Y - H:i:s") }} von {{ article.createdBy.username }}</p>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
            {% if pages >= 2 %}
                <div class="pagination">
                    <button class="page first" value="1" type="button" form="articleFilter" {% if page == 1 %}disabled{% endif %}><i class="fa-solid fa-backward-fast"></i></button>
                    <button class="page prev" value="{{ page - 1 }}" type="button" form="articleFilter" {% if page == 1 %}disabled{% endif %}><i class="fa-solid fa-backward-step"></i></button>
                    {% for i in 1..pages %}
                        <button class="page" value="{{ i }}" type="button" form="articleFilter" {% if i == page %}disabled{% endif %}>{{ i }}</button>
                    {% endfor %}
                    <button class="page next" value="{{ page + 1 }}" type="button" form="articleFilter" {% if page == pages %}disabled{% endif %}><i class="fa-solid fa-forward-step"></i></button>
                    <button class="page last" value="{{ pages }}" type="button" form="articleFilter" {% if page == pages %}disabled{% endif %}><i class="fa-solid fa-forward-fast"></i></button>
                </div>
            {% endif %}
        {% endif %}
    {% else %}
        {{ _self.notLoggedIn() }}
    {% endif %}
{% endblock %}

{% block asideRight %}
    {% if loggedIn %}
        <ul>
            <li><b>Veröffentlicht:</b> {{ project.published|date("d.m.Y - H:i:s") }} Uhr</li>
            <li><b>Ersteller:</b> <a href="/profile?id={{ project.createdBy.id }}">{{ project.createdBy.username }}</a></li>
            {% if project.published|date("d.m.Y - H:i:s") != project.lastEdit|date("d.m.Y - H:i:s") %}
                <li><b>Letzte Änderung:</b> {{ project.lastEdit|date("d.m.Y - H:i:s") }} Uhr</li>
                <li><b>Letzte Änderung von:</b> <a href="/profile?id={{ project.lastEditBy.id }}">{{ project.lastEditBy.username }}</a></li>
            {% endif %}
            {% if project.parentProject.name != null %}
                <li><b>Übergeordnetes Projekt:</b> <a href="/project/detail?id={{ project.parentProject.id }}&filter=called&page=1">{{ project.parentProject.name }}</a></li>
            {% endif %}
            <li><b>Privat:</b>
                {% if project.private %}
                    Ja
                {% else %}
                    Nein
                {% endif %}
            </li>
        </ul>
    {% endif %}
{% endblock %}