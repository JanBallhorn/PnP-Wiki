RewriteEngine on
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ index.php?q=$1 [L,QSA]

# Kein Verzeichnis-Listing
Options -Indexes

# Dotfiles (.env, .htaccess, .phpunit.result.cache, ...) nie ausliefern
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Konkret sensible Dateien nie ausliefern
<FilesMatch "^(db_credentials\.txt|whitelist\.json|composer\.(json|lock|phar)|phpunit\.phar)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
